# ======================
# API Keys
# ======================
GEMINI_API_KEY=your_gemini_api_key_here

# ======================
# SSH Server Config (WordPress 호스팅 서버)
# ======================
SSH_HOST=your_server_ip
SSH_USER=ubuntu
SSH_KEY_PATH=/path/to/your/ssh-key.pem

# ======================
# Server Settings
# ======================
WEB_ROOT=/var/www
