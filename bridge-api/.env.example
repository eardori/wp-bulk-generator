# Bridge API 인증
BRIDGE_API_KEY=your_bridge_api_key_here
BRIDGE_JWT_SECRET=your_jwt_secret_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# 서버 경로
CREDENTIALS_PATH=/root/wp-sites-credentials.json
CONFIG_PATH=/root/wp-sites-config.json
GROUPS_PATH=/home/ubuntu/wp-bridge-api/data/site-groups.json
DEPLOY_SCRIPT_PATH=/home/ubuntu/wp-bulk-generator/scripts/deploy-wp-sites.sh

# CORS (Vercel 도메인)
CORS_ORIGIN=https://wp-bulk-generator.vercel.app

# 서버 설정
PORT=4000
HOST=127.0.0.1
