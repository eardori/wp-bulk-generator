# ============================
# Bridge API + EC2 Agent (Lightsail 통합)
# ============================

# 인증
BRIDGE_API_KEY=your_bridge_api_key_here
BRIDGE_JWT_SECRET=your_jwt_secret_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# EC2 Agent 연결 (같은 서버 — localhost)
EC2_AGENT_URL=http://127.0.0.1:4001
EC2_AGENT_KEY=your_bridge_api_key_here

# CORS (쉼표로 여러 origin 지정 가능)
CORS_ORIGIN=https://wp.multiful.ai,https://wp-bulk-generator.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Bridge API 서버 설정
PORT=4000
HOST=0.0.0.0

# ============================
# EC2 Agent 설정 (같은 .env 파일에서 읽음)
# ============================
EC2_AGENT_PORT=4001
CREDENTIALS_PATH=/home/ubuntu/wp-bulk-generator/bridge-api/data/wp-sites-credentials.json
CONFIG_PATH=/home/ubuntu/wp-bulk-generator/bridge-api/data/wp-sites-config.json
GROUPS_PATH=/home/ubuntu/wp-bulk-generator/bridge-api/data/site-groups.json
DEPLOY_SCRIPT_PATH=/home/ubuntu/wp-bulk-generator/scripts/deploy-wp-sites.sh
